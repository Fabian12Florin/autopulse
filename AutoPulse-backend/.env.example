# -------------------------------------------------
# Core ports
# -------------------------------------------------
DISCOVERY_PORT=8761
GATEWAY_PORT=8080
FLEET_PORT=8082
USER_PORT=8084
GEOGRAPHY_PORT=8085
PARCEL_SERVER_PORT=8083
DELIVERY_SERVER_PORT=8086
ROUTING_SERVER_PORT=8081
NOTIFICATION_PORT=8111

# -------------------------------------------------
# Infrastructure
# -------------------------------------------------
KEYCLOAK_PORT=8008
KAFKA_EXTERNAL_PORT=9094
KAFKA_CLUSTER_ID=autopulse-local-cluster-id-001
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# -------------------------------------------------
# Keycloak
# -------------------------------------------------
KEYCLOAK_REALM=autopulse
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=admin

KEYCLOAK_DB_HOST=autopulse-postgres
KEYCLOAK_DB_PORT=5432
KEYCLOAK_DB_NAME=keycloak_db
KEYCLOAK_DB_SCHEMA=public
KEYCLOAK_DB_USERNAME=keycloak_user
KEYCLOAK_DB_PASSWORD=keycloak_password

KEYCLOAK_USER_SERVICE_CLIENT_ID=user-service-client
KEYCLOAK_USER_SERVICE_CLIENT_SECRET=replace-with-secret
KEYCLOAK_ROLE_ADMIN=ADMIN
KEYCLOAK_ROLE_DISPATCHER=DISPATCHER
KEYCLOAK_ROLE_COURIER=COURIER

OAUTH2_ISSUER_URI=http://keycloak:8080/realms/autopulse

# -------------------------------------------------
# Service databases (one DB per service)
# Works with infra/postgres/sql/01-create-microservice-database.sql
# -------------------------------------------------
FLEET_DB_URL=jdbc:postgresql://autopulse-postgres:5432/fleet_db
FLEET_DB_USERNAME=fleet_user
FLEET_DB_PASSWORD=fleet_password

USER_DB_HOST=autopulse-postgres
USER_DB_PORT=5432
USER_DB_NAME=user_db
USER_DB_SCHEMA=public
USER_DB_USERNAME=user_user
USER_DB_PASSWORD=user_password
USER_DB_URL=jdbc:postgresql://autopulse-postgres:5432/user_db?currentSchema=public

GEOGRAPHY_DB_HOST=autopulse-postgres
GEOGRAPHY_DB_PORT=5432
GEOGRAPHY_DB_NAME=geography_db
GEOGRAPHY_DB_SCHEMA=public
GEOGRAPHY_DB_USERNAME=geography_user
GEOGRAPHY_DB_PASSWORD=geography_password
GEOGRAPHY_DB_URL=jdbc:postgresql://autopulse-postgres:5432/geography_db?currentSchema=public

PARCEL_DB_HOST=autopulse-postgres
PARCEL_DB_PORT=5432
PARCEL_DB_NAME=parcel_db
PARCEL_DB_SCHEMA=public
PARCEL_DB_USER=parcel_user
PARCEL_DB_PASSWORD=parcel_password
PARCEL_DB_URL=jdbc:postgresql://autopulse-postgres:5432/parcel_db

DELIVERY_DB_HOST=autopulse-postgres
DELIVERY_DB_PORT=5432
DELIVERY_DB_NAME=delivery_db
DELIVERY_DB_SCHEMA=public
DELIVERY_DB_USER=delivery_user
DELIVERY_DB_PASSWORD=delivery_execution_password
DELIVERY_DB_URL=jdbc:postgresql://autopulse-postgres:5432/delivery_db

ROUTING_DB_HOST=autopulse-postgres
ROUTING_DB_PORT=5432
ROUTING_DB_NAME=routing_db
ROUTING_DB_SCHEMA=public
ROUTING_DB_USER=routing_user
ROUTING_DB_PASSWORD=routing_password
ROUTING_DB_URL=jdbc:postgresql://autopulse-postgres:5432/routing_db

# -------------------------------------------------
# Notifications / email
# -------------------------------------------------
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=dev@example.com
MAIL_PASSWORD=dev-password
MAIL_SMTP_CONNECTION_TIMEOUT=5000
MAIL_SMTP_TIMEOUT=3000
MAIL_SMTP_WRITE_TIMEOUT=5000
APP_LOGIN_URL=http://localhost:5173/login
SUPPORT_EMAIL=support@example.com
